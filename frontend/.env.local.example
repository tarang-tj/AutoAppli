NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Canonical URL for Open Graph, sitemap, and robots (production). Falls back to VERCEL_URL on Vercel.
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# FastAPI — MUST be your backend host (Render/Fly/Railway), NOT the Next.js site (e.g. not autoappli.com).
# Examples: https://autoappli-api.onrender.com  OR  http://127.0.0.1:8000 (local dev only, same machine)
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com
