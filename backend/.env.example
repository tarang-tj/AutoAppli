SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT Secret (Settings → API). With URL + service role + this secret, /jobs/* persist to Postgres (see supabase/migrations/).
SUPABASE_JWT_SECRET=your-jwt-secret
ANTHROPIC_API_KEY=sk-ant-your-key
# Comma-separated browser origins allowed to call this API (your Vercel URL, no trailing slash).
# Local Next.js: add http://localhost:3000
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
